{
    "name": "mcp-server-sfmc",
    "version": "0.3.0",
    "mcpName": "io.github.JoernBerkefeld/mcp-server-sfmc",
    "description": "SFMC AMPscript/SSJS/GTL tools and searchable Marketing Cloud Engagement help (MCE vs Next scoped) via MCP.",
    "author": "JÃ¶rn Berkefeld",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/JoernBerkefeld/mcp-server-sfmc.git"
    },
    "bugs": {
        "url": "https://github.com/JoernBerkefeld/mcp-server-sfmc/issues"
    },
    "homepage": "https://github.com/JoernBerkefeld/mcp-server-sfmc#readme",
    "keywords": [
        "mcp",
        "model-context-protocol",
        "ampscript",
        "ssjs",
        "sfmc",
        "salesforce",
        "marketing-cloud",
        "ai",
        "copilot",
        "code-review"
    ],
    "type": "module",
    "bin": {
        "mcp-server-sfmc": "./dist/index.js",
        "sfmc-review-diff": "./dist/cli/reviewDiff.js"
    },
    "main": "./dist/index.js",
    "exports": {
        ".": "./dist/index.js"
    },
    "files": [
        "dist",
        "bundled",
        "ci-templates",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "prepublishOnly": "npm run build",
        "bundle-mce-help": "node scripts/bundle-mce-help.mjs",
        "build": "tsc -p tsconfig.json",
        "dev": "tsc -p tsconfig.json --watch",
        "start": "node dist/index.js",
        "review-diff": "node dist/cli/reviewDiff.js",
        "pretest": "npm run build",
        "test": "node --test tests/*.test.mjs",
        "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
        "lint": "eslint .",
        "lint:fix": "eslint --fix .",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "sfmc-language-lsp": "^0.1.3"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^22.19.17",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jsdoc": "^62.0.0",
        "eslint-plugin-prettier": "^5.5.0",
        "eslint-plugin-unicorn": "^64.0.0",
        "globals": "^17.4.0",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.2"
    }
}
